# ScrapeOwl Environment Configuration
# Copy this file to .env and fill in your values

# ===== AI Configuration =====
# OpenAI API key for AI-powered extraction
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Claude API key (alternative to OpenAI)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ===== CAPTCHA Solvers =====
# 2captcha API key (https://2captcha.com)
CAPTCHA_API_KEY=your-2captcha-key-here

# AntiCaptcha API key (https://anti-captcha.com)
# ANTICAPTCHA_API_KEY=your-anticaptcha-key-here

# ===== Server Configuration =====
# Port to listen on (default: 8080)
PORT=8080

# Database file path (default: ./scrapeowl.db)
DB_PATH=./scrapeowl.db

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
